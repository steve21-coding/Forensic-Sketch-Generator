    "### 3. Multi-Model Lifespan Bootstrapping and Public Network Tunnel Generation"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "cell_3_server"
   },
   "source": [
    "# Paste ngrok security token inside the string below\n",
    "NGROK_AUTHTOKEN = 'PASTE_YOUR_NGROK_TOKEN_HERE'\n",
    "\n",
    "import nest_asyncio\n",
    "import uvicorn\n",
    "import threading\n",
    "from pyngrok import ngrok, conf\n",
    "\n",
    "nest_asyncio.apply()\n",
    "conf.get_default().auth_token = NGROK_AUTHTOKEN\n",
    "\n",
    "# Close lingering network bridges\n",
    "ngrok.kill()\n",
    "\n",
    "# Bridge HTTP tunnel directly over to port 8000\n",
    "tunnel = ngrok.connect(8000, 'http')\n",
    "public_url = tunnel.public_url\n",
    "\n",
    "print('\\n' + '='*70)\n",
    "print(f' Public URL Link Generated:')\n",
    "print(f' {public_url}')\n",
    "print('='*70)\n",
    "print(' Copy the secure URL generated above, paste it directly into your local\\n operator dashboard network configuration input box, and select CONNECT.\\n' + '='*70 + '\\n')\n",
    "\n",
    "# Route ASGI application parameters to target backend/main.py -> app instantiation\n",
    "def run_server():\n",
    "    uvicorn.run('backend.main:app', host='0.0.0.0', port=8000, log_level='info')\n",
    "\n",
    "# Boot web engine on dedicated isolated daemon thread to hold active session runtimes\n",
    "t = threading.Thread(target=run_server, daemon=True)\n",
    "t.start()\n",
    "\n",
    "print('Staging pipeline configurations and parsing weights to cloud GPU VRAM. Monitor logs...')"
   ],
